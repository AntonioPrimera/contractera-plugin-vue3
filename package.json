{
  "name": "@raprim/contractera-plugin-vue3",
  "version": "0.1.0",
  "description": "Vue 3 SDK components for Contractera document workflows.",
  "type": "module",
  "private": false,
  "files": [
    "dist"
  ],
  "main": "./dist/contractera-plugin-vue3.cjs",
  "module": "./dist/contractera-plugin-vue3.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/contractera-plugin-vue3.js",
      "require": "./dist/contractera-plugin-vue3.cjs"
    },
    "./styles": "./dist/contractera-plugin-vue3.css"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
